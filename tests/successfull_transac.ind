func calculateBonus(balance, performance)
    given balance > 1000
    given performance > 5
{
    // Initialize local variables
    bonus = 0;
    
    // Branching logic: performance affects the multiplier
    if (performance > 8) {
        bonus = balance * 0.10;
    }

    // Iterative logic: simulate 3 periods of interest
    count = 0;
    while (count < 3) {
        balance = balance + bonus;
        count = count + 1;
    }

    return balance;
}
    ensure balance > 1000